# Mobi Estimating API — environment variable reference.
# Copy to `.env` and adjust. All variables are prefixed with MOBI_.

# Security — current engine auth remains local/internal only until tenant-scoped
# JWT/workload identity is implemented. `local` keeps the development harness
# available; `staging`/`production` intentionally fail closed in the current
# codebase and must not be used until a future P0 tenant-boundary implementation
# updates the startup guard and request enforcement together.
MOBI_DEPLOYMENT_ENVIRONMENT=local
MOBI_ENGINE_AUTH_MODE=local_dev_open
# Optional local/internal shared-secret API key. Leave blank with
# MOBI_ENGINE_AUTH_MODE=local_dev_open for the keyless local harness. To exercise
# the temporary shared-key middleware, set MOBI_ENGINE_AUTH_MODE=local_dev_shared_key
# and set MOBI_API_KEY to a non-blank local secret. The shared key is not
# sufficient for staging or production tenant isolation.
MOBI_API_KEY=

# Storage
MOBI_DB_PATH=data/mobi.db
MOBI_UPLOAD_DIR=data/uploads

# Upload limits (bytes). Default = 100 MiB.
MOBI_MAX_UPLOAD_BYTES=104857600
MOBI_UPLOAD_CHUNK_BYTES=1048576

# Phase 2 — deterministic blueprint processing
MOBI_RENDER_DPI=150
MOBI_THUMBNAIL_MAX_WIDTH=320
MOBI_MIN_TEXT_CHARS=12
MOBI_MAX_PAGE_COUNT=1000
MOBI_MAX_RENDER_PIXELS=40000000
# Run processing inline in the request (true) or via a background task (false).
MOBI_PROCESS_INLINE=true

# Phase 3 — trade-agnostic extraction framework
# Comma-separated trade codes to register/enable. demo_concrete is a
# demonstration trade; do not enable it in production unless intentionally testing.
MOBI_ENABLED_TRADES=painting
# Provider: "mock" (deterministic, offline, default) or "openai".
MOBI_EXTRACTION_PROVIDER=mock
# Live AI extraction is OFF by default. The app runs fully without a key.
MOBI_ENABLE_LIVE_EXTRACTION=false
# Secret — never commit a real key. Leave blank to run offline with the mock.
MOBI_OPENAI_API_KEY=
# Exact GPT-5.6 alias for the Responses API + Structured Outputs path. Enforced:
# only the exact value `gpt-5.6` is accepted (config fails closed otherwise).
MOBI_OPENAI_MODEL=gpt-5.6
# Reasoning effort. GPT-5.6 documents none|low|medium|high|xhigh|max, but this
# build intentionally enforces `medium` only; any other value fails closed.
MOBI_OPENAI_REASONING_EFFORT=medium
MOBI_EXTRACTION_MAX_PAGES=50
MOBI_EXTRACTION_MAX_PAGES_PER_TRADE=50
MOBI_EXTRACTION_MAX_TEXT_CHARS_PER_PAGE=20000
MOBI_EXTRACTION_TIMEOUT_SECONDS=60
MOBI_EXTRACTION_MAX_RETRIES=2
# Raw provider responses may contain customer plan text; off by default.
MOBI_EXTRACTION_STORE_RAW_RESPONSE=false
MOBI_EXTRACTION_INLINE=true
MOBI_EXTRACTION_CACHE_ENABLED=true

# --- GPT-5.6 structured project-analysis layer ---
# Fail-closed reasoning/review layer (Responses API + Structured Outputs).
# Live calls require BOTH a key above AND this flag; default OFF (no network).
MOBI_ENABLE_LIVE_PROJECT_ANALYSIS=false
MOBI_PROJECT_ANALYSIS_SCHEMA_VERSION=1.0
MOBI_PROJECT_ANALYSIS_MAX_SOURCE_DOCUMENTS=40
MOBI_PROJECT_ANALYSIS_MAX_SOURCE_CHARS=120000
MOBI_PROJECT_ANALYSIS_MAX_CHARS_PER_DOCUMENT=20000
MOBI_PROJECT_ANALYSIS_TIMEOUT_SECONDS=120
MOBI_PROJECT_ANALYSIS_MAX_RETRIES=2

# Logging
MOBI_LOG_LEVEL=INFO
MOBI_JSON_LOGS=false

# Metadata (rarely changed)
MOBI_APP_VERSION=0.1.0
MOBI_API_V1_PREFIX=/api/v1
