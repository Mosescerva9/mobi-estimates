# Mobi Estimating API — environment variable reference.
# Copy to `.env` and adjust. All variables are prefixed with MOBI_.

# Storage
MOBI_DB_PATH=data/mobi.db
MOBI_UPLOAD_DIR=data/uploads

# Upload limits (bytes). Default = 100 MiB.
MOBI_MAX_UPLOAD_BYTES=104857600
MOBI_UPLOAD_CHUNK_BYTES=1048576

# Logging
MOBI_LOG_LEVEL=INFO
MOBI_JSON_LOGS=false

# Metadata (rarely changed)
MOBI_APP_VERSION=0.1.0
MOBI_API_V1_PREFIX=/api/v1
