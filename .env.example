# Mobi Estimates — Client Portal : environment contract
# Copy to .env.local and fill in real values. NEVER commit .env.local.
#
# Supabase ────────────────────────────────────────────────────────────────
# Project API URL and anon (publishable) key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Service-role key BYPASSES Row Level Security. SERVER-ONLY. Never prefix with
# NEXT_PUBLIC_. Used by Stripe webhooks / admin tasks (Milestone 2+).
# Copy it from: Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth bootstrap ──────────────────────────────────────────────────────────
# Comma-separated emails that should be promoted to the 'admin' role on signup.
ADMIN_BOOTSTRAP_EMAILS=

# Stripe (Milestone 2) ────────────────────────────────────────────────────
# Server-only. Never prefix with NEXT_PUBLIC_.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs — one recurring monthly Price per plan + one one-time Price.
# STRIPE_PRICE_STARTER=price_...                 # $995/mo recurring
# STRIPE_PRICE_GROWTH=price_...                  # $1,995/mo recurring
# STRIPE_PRICE_ESTIMATING_DEPARTMENT=price_...   # $2,995/mo recurring
# STRIPE_PRICE_PAY_PER_PROJECT=price_...         # $199 one-time
# 50%-off-first-month coupon: create with percent_off=50, duration=once.
# STRIPE_FIRST_MONTH_COUPON_ID=                  # e.g. "FIRSTMONTH50" or a coupon id
# NOTE: Mobi Estimates offers NO free trial — never set trial_period_days/trial_end.

# Resend (Milestone 6) ─────────────────────────────────────────────────────
# RESEND_API_KEY=
# EMAIL_FROM=
